# ═══════════════════════════════════════════════════════════════════════════
#  META ADS MCP — Environment Configuration
# ═══════════════════════════════════════════════════════════════════════════

# ── Server ──
PORT=3000
NODE_ENV=production

# ── Meta API ──
META_ACCESS_TOKEN=
META_AD_ACCOUNT_ID=
META_API_VERSION=v22.0
META_APP_ID=
META_APP_SECRET=

# ── Database ──
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/meta_ads_mcp
REDIS_URL=redis://localhost:6379/0

# ── Encryption ──
# Generate a strong 32-byte hex key: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=

# ── Auth ──
JWT_SECRET=
JWT_EXPIRES_IN=7d

# ── MCP Server API Key (master key for direct access) ──
MCP_API_KEY=

# ── OAuth ──
OAUTH_REDIRECT_URL=https://meta-ads.hellenicai.com/auth/meta/callback

# ── Tiers ──
FREE_WEEKLY_EXECUTIONS=30
FREE_MAX_AD_ACCOUNTS=2
